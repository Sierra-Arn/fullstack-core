# =============================================================================
# Server Config
# =============================================================================
SERVER_HOST="0.0.0.0"
SERVER_PORT=8000
SERVER_LOG_LEVEL="INFO"
SERVER_APP_NAME="Full-Stack Core"
SERVER_UI_THEME="light"
SERVER_INFERENCE_QUOTA=3
SERVER_PAGE_SIZE=10
SERVER_DEEP_HEALTH_TIMEOUT=3.0


# =============================================================================
# PostgreSQL Config
# =============================================================================
POSTGRES_SUPERUSER_NAME="postgres_admin"
POSTGRES_SUPERUSER_PASSWORD="changeme"
POSTGRES_SYSTEM_DB_NAME="postgres_db"
POSTGRES_USER_NAME="postgres_user"
POSTGRES_USER_PASSWORD="changeme"
POSTGRES_USER_DB_NAME="user_db"
POSTGRES_HOST="127.0.0.1"
POSTGRES_INTERNAL_PORT=5432
POSTGRES_EXTERNAL_PORT=5432
POSTGRES_PORT=${POSTGRES_EXTERNAL_PORT}


# =============================================================================
# Redis Config
# =============================================================================
REDIS_ADMIN_NAME="redis_admin"
REDIS_ADMIN_PASSWORD="changeme"
REDIS_USER_NAME="redis_user"
REDIS_USER_PASSWORD="changeme"
REDIS_HOST="127.0.0.1"
REDIS_INTERNAL_PORT=6379
REDIS_EXTERNAL_PORT=6379
REDIS_PORT=${REDIS_EXTERNAL_PORT}
REDIS_SESSION_DB_INDEX=0
REDIS_RATE_LIMIT_DB_INDEX=1
REDIS_BROKER_DB_INDEX=2
REDIS_RESULT_BACKEND_DB_INDEX=3


# =============================================================================
# Session Config
# =============================================================================
SESSION_TTL_SECONDS=86400
SESSION_SESSION_ID_LENGTH=32
SESSION_COOKIE_NAME="session_id"
SESSION_COOKIE_PATH=/
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=true


# =============================================================================
# Password Config
# =============================================================================
PASSWORD_BCRYPT_ROUNDS=12


# =============================================================================
# Rate Limit Config
# =============================================================================
RATE_LIMIT_MAX_REQUESTS=50
RATE_LIMIT_WINDOW_SECONDS=60


# =============================================================================
# Celery Config
# =============================================================================
CELERY_APP_NAME="fullstack-backend"
CELERY_RESULT_EXPIRES=3600
CELERY_QUEUE_NAME_INFERENCE="inference-queue"
CELERY_TASK_NAME_INFERENCE="generate"
CELERY_QUEUE_NAME_MAINTENANCE="maintenance-queue"
CELERY_TASK_NAME_RESET_INFERENCE_COUNTS="reset_inference_counts"
CELERY_EXCHANGE_NAME="tasks"
CELERY_HOUR_RESET_INFERENCE_COUNTS=0
CELERY_MINUTE_RESET_INFERENCE_COUNTS=0


# =============================================================================
# Worker Inference Config
# =============================================================================
WORKER_INFERENCE_NAME="worker_inference@%n"
WORKER_INFERENCE_MODEL_PATH="Qwen/Qwen3.5-2B"
WORKER_INFERENCE_DEVICE="cuda"
WORKER_INFERENCE_LOG_LEVEL="INFO"


# =============================================================================
# Worker Maintenance Config
# =============================================================================
WORKER_MAINTENANCE_NAME="worker_maintenance@%n"
WORKER_MAINTENANCE_LOG_LEVEL="INFO"
WORKER_MAINTENANCE_BEAT_SCHEDULE_PATH="celery-beat/celerybeat-schedule"
WORKER_MAINTENANCE_BEAT_PIDFILE_PATH="celery-beat/celerybeat.pid"


# ====================================================
# Seed Config
# ====================================================
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="changeme"
SEED_USERS_COUNT=57
SEED_LEADS_COUNT=34
SEED_INFERENCE_HISTORY_COUNT=15